{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Webcmd",
  "description": "An agent runtime for turning websites, apps, APIs, and local tools into deterministic CLIs.",
  "colors": {
    "primary": "#006B9A",
    "light": "#56C5FF",
    "dark": "#006B9A"
  },
  "logo": {
    "light": "/webcmd.svg",
    "dark": "/webcmd.svg",
    "href": "https://webcmd.dev"
  },
  "favicon": "/webcmd.svg",
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "light": "#F1EFE7",
      "dark": "#0D0F11"
    }
  },
  "fonts": {
    "heading": {
      "family": "Newsreader",
      "weight": 500
    },
    "body": {
      "family": "Manrope",
      "weight": 400
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Start",
            "pages": [
              "index",
              "quickstart",
              "concepts"
            ]
          },
          {
            "group": "Work With Agents",
            "pages": [
              "agent-prompts",
              "cli-reference",
              "agent-runtime",
              "generated-clis",
              "x-session-cli"
            ]
          },
          {
            "group": "Extend",
            "pages": [
              "authoring",
              "plugins-and-skills"
            ]
          },
          {
            "group": "Support",
            "pages": [
              "troubleshooting"
            ]
          }
        ]
      }
    ]
  }
}
